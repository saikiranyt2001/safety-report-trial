{
  "dashboard": {
    "id": null,
    "title": "Backend Metrics",
    "panels": [
      {
        "type": "graph",
        "title": "Request Rate",
        "targets": [
          {
            "expr": "http_requests_total",
            "format": "time_series"
          }
        ],
        "datasource": "Prometheus"
      },
      {
        "type": "graph",
        "title": "Request Duration",
        "targets": [
          {
            "expr": "http_request_duration_seconds_bucket",
            "format": "time_series"
          }
        ],
        "datasource": "Prometheus"
      }
    ],
    "schemaVersion": 16,
    "version": 1
  },
  "overwrite": true
}
